{
  "name": "nuxt-template",
  "type": "module",
  "private": true,
  "description": "Nuxt 4 starter with Better Auth (Google), Drizzle/Turso, Tailwind v4, antfu eslint, and husky.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "concurrently \"pnpm run dev:db\" \"nuxt dev\"",
    "dev:db": "turso dev --db-file local.db",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@libsql/client": "^0.17.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "^0.11.0",
    "@nuxt/icon": "^2.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.2.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "better-auth": "^1.5.3",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.1",
    "eslint": "10.0.2",
    "nuxt": "^4.4.4",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@iconify-json/lucide": "^1.2.0",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*": "pnpm lint"
  }
}
