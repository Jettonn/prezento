#!/usr/bin/env sh
# Load nvm if available so the hook always uses the project's required Node
# version (see .nvmrc and package.json#engines). Without this, hooks invoked
# from GUI clients or shells that haven't loaded nvm will use the system Node.
if [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ]; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null 2>&1 || true
fi

pnpm exec lint-staged
